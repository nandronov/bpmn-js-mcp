{
  "name": "bpmn-js-mcp",
  "version": "1.0.0",
  "description": "MCP server for creating and manipulating BPMN diagrams using bpmn-js",
  "main": "dist/index.js",
  "scripts": {
    "build": "node esbuild.config.mjs",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build",
    "watch": "node esbuild.config.mjs --watch",
    "dev": "nodemon",
    "start": "node dist/index.js",
    "eval": "node dist/eval-cli.js",
    "eval:ci": "node dist/eval-cli.js --failBelowScore 70",
    "agent-loop": "node dist/agent-loop-cli.js",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint src/ test/",
    "lint:fix": "eslint src/ test/ --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:acceptance": "vitest run test/acceptance/",
    "test:coverage": "vitest run --coverage",
    "coverage": "vitest run --coverage",
    "update:snapshots": "vitest run test/handlers/layout/reference-snapshots.test.ts",
    "bundle-size": "node -e \"const s=require('fs').statSync('dist/index.js').size; console.log('Bundle: '+(s/1024).toFixed(1)+'KB ('+s+' bytes)')\""
  },
  "keywords": [
    "mcp",
    "bpmn",
    "bpmn-js",
    "workflow",
    "diagram"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist/",
    "fonts/",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@resvg/resvg-js": "^2.6.2",
    "bpmn-auto-layout": "^1.2.0",
    "bpmn-js": "^18.8.0",
    "bpmnlint": "^11.10.0",
    "bpmnlint-plugin-camunda-compat": "^2.47.0",
    "camunda-bpmn-moddle": "^7.0.1",
    "jsdom": "^25.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/bpmn-moddle": "^9.0.0",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/eslint-plugin": "^1.6.14",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.2",
    "eslint-plugin-sonarjs": "^4.0.2",
    "eslint-plugin-unicorn": "^63.0.0",
    "nodemon": "^3.1.11",
    "prettier": "^3.8.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.54.0",
    "vitest": "^4.0.18"
  },
  "bin": {
    "bpmn-js-mcp": "./dist/index.js"
  }
}
