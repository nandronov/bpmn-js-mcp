<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:process id="Process_Executable_Process_-_Camunda_7_no_pool" name="Executable Process - Camunda 7 (no pool)" isExecutable="true" camunda:historyTimeToLive="P180D">
    <bpmn:startEvent id="StartEvent_Start" name="Start">
      <bpmn:outgoing>Flow_14fhzq3</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="UserTask_SubmitRequest" name="Submit Request" camunda:assignee="initiator">
      <bpmn:extensionElements>
        <camunda:formData>
          <camunda:formField id="requestId" label="Request ID" type="string">
            <camunda:validation>
              <camunda:constraint name="required" />
            </camunda:validation>
          </camunda:formField>
          <camunda:formField id="amount" label="Amount" type="long">
            <camunda:validation>
              <camunda:constraint name="required" />
            </camunda:validation>
          </camunda:formField>
          <camunda:formField id="description" label="Description" type="string" />
        </camunda:formData>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_14fhzq3</bpmn:incoming>
      <bpmn:outgoing>Flow_004nk67</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="Flow_14fhzq3" sourceRef="StartEvent_Start" targetRef="UserTask_SubmitRequest" />
    <bpmn:serviceTask id="ServiceTask_ValidateRequest" name="Validate Request" camunda:type="external" camunda:topic="validate-request">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:outputParameter name="valid">${true}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_004nk67</bpmn:incoming>
      <bpmn:outgoing>Flow_172nyqb</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_004nk67" sourceRef="UserTask_SubmitRequest" targetRef="ServiceTask_ValidateRequest" />
    <bpmn:exclusiveGateway id="Gateway_DecisionValid" name="Decision - Valid?" default="Flow_NeedsReview">
      <bpmn:incoming>Flow_172nyqb</bpmn:incoming>
      <bpmn:outgoing>Flow_Valid</bpmn:outgoing>
      <bpmn:outgoing>Flow_NeedsReview</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_172nyqb" sourceRef="ServiceTask_ValidateRequest" targetRef="Gateway_DecisionValid" />
    <bpmn:businessRuleTask id="BusinessRuleTask_EvaluatePolicy" name="Evaluate Policy" camunda:decisionRef="policy_decision">
      <bpmn:incoming>Flow_Valid</bpmn:incoming>
      <bpmn:outgoing>Flow_EvaluationComplete</bpmn:outgoing>
    </bpmn:businessRuleTask>
    <bpmn:userTask id="UserTask_ManagerReview" name="Review Request" camunda:candidateGroups="managers">
      <bpmn:extensionElements>
        <camunda:formData>
          <camunda:formField id="approved" label="Approved?" type="boolean" defaultValue="false" />
          <camunda:formField id="comment" label="Comment" type="string" />
        </camunda:formData>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_NeedsReview</bpmn:incoming>
      <bpmn:outgoing>Flow_ReadyForProcessing</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="ServiceTask_ProcessOrder" name="Process Order" camunda:type="external" camunda:topic="process-order">
      <bpmn:incoming>Flow_MergeProcess</bpmn:incoming>
      <bpmn:outgoing>Flow_0ktyfg3</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_End" name="End">
      <bpmn:incoming>Flow_0ktyfg3</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_0ktyfg3" sourceRef="ServiceTask_ProcessOrder" targetRef="EndEvent_End" />
    <bpmn:sequenceFlow id="Flow_Valid" name="Valid" sourceRef="Gateway_DecisionValid" targetRef="BusinessRuleTask_EvaluatePolicy">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${valid == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_NeedsReview" name="Needs Review" sourceRef="Gateway_DecisionValid" targetRef="UserTask_ManagerReview">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${valid == false}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:exclusiveGateway id="Gateway_MergeToProcessOrder" name="Merge - To Process Order" default="Flow_MergeProcess">
      <bpmn:incoming>Flow_EvaluationComplete</bpmn:incoming>
      <bpmn:incoming>Flow_ReadyForProcessing</bpmn:incoming>
      <bpmn:outgoing>Flow_MergeProcess</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_EvaluationComplete" name="Evaluation Complete" sourceRef="BusinessRuleTask_EvaluatePolicy" targetRef="Gateway_MergeToProcessOrder" />
    <bpmn:sequenceFlow id="Flow_ReadyForProcessing" name="Ready for Processing" sourceRef="UserTask_ManagerReview" targetRef="Gateway_MergeToProcessOrder" />
    <bpmn:sequenceFlow id="Flow_MergeProcess" name="Merge → Process" sourceRef="Gateway_MergeToProcessOrder" targetRef="ServiceTask_ProcessOrder" />
  </bpmn:process>
