          <dc:Bounds x="633" y="358" width="84" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="UserTask_ManagerApproval_di" bpmnElement="UserTask_ManagerApproval">
        <dc:Bounds x="750" y="290" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Approved_di" bpmnElement="Gateway_Approved" isMarkerVisible="true">
        <dc:Bounds x="900" y="305" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="898" y="358" width="54" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ServiceTask_ProcessOrder_di" bpmnElement="ServiceTask_ProcessOrder">
        <dc:Bounds x="1000" y="290" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ServiceTask_SendConfirmation_di" bpmnElement="ServiceTask_SendConfirmation">
        <dc:Bounds x="1150" y="290" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_OrderProcessed_di" bpmnElement="EndEvent_OrderProcessed">
        <dc:Bounds x="1300" y="312" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1276" y="351" width="84" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_OrderInvalid_di" bpmnElement="EndEvent_OrderInvalid">
        <dc:Bounds x="500" y="182" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="487" y="221" width="63" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ServiceTask_NotifyRejection_di" bpmnElement="ServiceTask_NotifyRejection">
        <dc:Bounds x="1100" y="410" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_OrderRejected_di" bpmnElement="EndEvent_OrderRejected">
        <dc:Bounds x="1260" y="442" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1241" y="481" width="75" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_RejectionJoin_di" bpmnElement="Gateway_RejectionJoin" isMarkerVisible="true">
        <dc:Bounds x="1000" y="420" width="50" height="50" />
