<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:process id="Process_Purchase_Order_Approval" name="Purchase Order Approval" isExecutable="true" camunda:historyTimeToLive="P180D">
    <bpmn:startEvent id="StartEvent_OrderSubmitted" name="Order Submitted">
      <bpmn:outgoing>Flow_0n6n3w7</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="ServiceTask_ValidateOrder" name="Validate Order" camunda:type="external" camunda:topic="validate-order">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:outputParameter name="isValid">${isValid}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0n6n3w7</bpmn:incoming>
      <bpmn:outgoing>Flow_14v7ld1</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_0n6n3w7" sourceRef="StartEvent_OrderSubmitted" targetRef="ServiceTask_ValidateOrder" />
    <bpmn:exclusiveGateway id="Gateway_IsValid" name="Is Valid?" default="Flow_No">
      <bpmn:incoming>Flow_14v7ld1</bpmn:incoming>
      <bpmn:outgoing>Flow_No</bpmn:outgoing>
      <bpmn:outgoing>Flow_Yes</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_14v7ld1" sourceRef="ServiceTask_ValidateOrder" targetRef="Gateway_IsValid" />
    <bpmn:businessRuleTask id="BusinessRuleTask_CheckCreditLimit" name="Check Credit Limit" camunda:resultVariable="creditSufficient" camunda:decisionRef="checkCreditLimit" camunda:mapDecisionResult="singleEntry">
      <bpmn:incoming>Flow_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_CheckCreditLimit_to_CreditSufficient</bpmn:outgoing>
    </bpmn:businessRuleTask>
    <bpmn:exclusiveGateway id="Gateway_CreditSufficient" name="Credit Sufficient?" default="Flow_q7u410n_No">
      <bpmn:incoming>Flow_CheckCreditLimit_to_CreditSufficient</bpmn:incoming>
      <bpmn:outgoing>Flow_t78gnwx_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_q7u410n_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="UserTask_ManagerApproval" name="Review and Decide" camunda:candidateGroups="managers" camunda:dueDate="">
      <bpmn:extensionElements>
        <camunda:formData>
          <camunda:formField id="decision" label="Decision" type="enum">
            <camunda:validation>
              <camunda:constraint name="required" />
            </camunda:validation>
            <camunda:value id="approve" name="Approve" />
            <camunda:value id="reject" name="Reject" />
          </camunda:formField>
          <camunda:formField id="comments" label="Comments" type="string" />
          <camunda:formField id="creditSufficient" label="Credit Sufficient (read-only)" type="boolean" defaultValue="${creditSufficient}" />
        </camunda:formData>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_t78gnwx_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_ManagerApproval_to_Approved</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_Approved" name="Approved?" default="Flow_p4sqee9_No">
      <bpmn:incoming>Flow_ManagerApproval_to_Approved</bpmn:incoming>
      <bpmn:outgoing>Flow_ye5qnei_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_p4sqee9_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="ServiceTask_ProcessOrder" name="Process Order" camunda:type="external" camunda:topic="process-order">
      <bpmn:incoming>Flow_ye5qnei_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_ProcessOrder_to_SendConfirmation</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="ServiceTask_SendConfirmation" name="Send Confirmation" camunda:type="external" camunda:topic="send-notification">
      <bpmn:incoming>Flow_ProcessOrder_to_SendConfirmation</bpmn:incoming>
      <bpmn:outgoing>Flow_SendConfirmation_to_OrderProcessed</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_OrderProcessed" name="Order Processed">
      <bpmn:incoming>Flow_SendConfirmation_to_OrderProcessed</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="EndEvent_OrderInvalid" name="Order Invalid">
      <bpmn:incoming>Flow_No</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="ServiceTask_NotifyRejection" name="Notify Rejection" camunda:type="external" camunda:topic="send-notification">
      <bpmn:incoming>Flow_RejectionJoin_to_NotifyRejection</bpmn:incoming>
      <bpmn:outgoing>Flow_NotifyRejection_to_OrderRejected</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_OrderRejected" name="Order Rejected">
      <bpmn:incoming>Flow_NotifyRejection_to_OrderRejected</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_No" name="No" sourceRef="Gateway_IsValid" targetRef="EndEvent_OrderInvalid" />
    <bpmn:sequenceFlow id="Flow_Yes" name="Yes" sourceRef="Gateway_IsValid" targetRef="BusinessRuleTask_CheckCreditLimit">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${isValid == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_CheckCreditLimit_to_CreditSufficient" sourceRef="BusinessRuleTask_CheckCreditLimit" targetRef="Gateway_CreditSufficient" />
    <bpmn:sequenceFlow id="Flow_t78gnwx_Yes" name="Yes" sourceRef="Gateway_CreditSufficient" targetRef="UserTask_ManagerApproval">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${creditSufficient == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_ManagerApproval_to_Approved" sourceRef="UserTask_ManagerApproval" targetRef="Gateway_Approved" />
    <bpmn:sequenceFlow id="Flow_ye5qnei_Yes" name="Yes" sourceRef="Gateway_Approved" targetRef="ServiceTask_ProcessOrder">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${decision == 'approve'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_ProcessOrder_to_SendConfirmation" sourceRef="ServiceTask_ProcessOrder" targetRef="ServiceTask_SendConfirmation" />
    <bpmn:sequenceFlow id="Flow_SendConfirmation_to_OrderProcessed" sourceRef="ServiceTask_SendConfirmation" targetRef="EndEvent_OrderProcessed" />
    <bpmn:sequenceFlow id="Flow_NotifyRejection_to_OrderRejected" sourceRef="ServiceTask_NotifyRejection" targetRef="EndEvent_OrderRejected" />
    <bpmn:exclusiveGateway id="Gateway_RejectionJoin" name="Rejection Join">
      <bpmn:incoming>Flow_q7u410n_No</bpmn:incoming>
      <bpmn:incoming>Flow_p4sqee9_No</bpmn:incoming>
      <bpmn:outgoing>Flow_RejectionJoin_to_NotifyRejection</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_q7u410n_No" name="No" sourceRef="Gateway_CreditSufficient" targetRef="Gateway_RejectionJoin" />
    <bpmn:sequenceFlow id="Flow_p4sqee9_No" name="No" sourceRef="Gateway_Approved" targetRef="Gateway_RejectionJoin" />
    <bpmn:sequenceFlow id="Flow_RejectionJoin_to_NotifyRejection" sourceRef="Gateway_RejectionJoin" targetRef="ServiceTask_NotifyRejection" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Process_Purchase_Order_Approval">
      <bpmndi:BPMNShape id="StartEvent_OrderSubmitted_di" bpmnElement="StartEvent_OrderSubmitted">
        <dc:Bounds x="160" y="182" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="138" y="221" width="81" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ServiceTask_ValidateOrder_di" bpmnElement="ServiceTask_ValidateOrder">
        <dc:Bounds x="250" y="160" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_IsValid_di" bpmnElement="Gateway_IsValid" isMarkerVisible="true">
        <dc:Bounds x="400" y="175" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="404" y="228" width="43" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
